// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Station {
  id            String         @id // Use the site_id from Gov API
  brand         String?
  address       String?
  postcode      String?
  lat           Float
  lng           Float
  prices        PriceHistory[]
  currentPrices CurrentPrice[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model PriceHistory {
  id        String   @id @default(cuid())
  stationId String
  fuelType  String // e.g., 'E10', 'B7', 'unleaded', 'diesel'
  price     Float
  timestamp DateTime // when the price was last updated according to the API

  station Station @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@unique([stationId, fuelType, timestamp])
  @@index([stationId])
  @@index([fuelType])
  @@index([timestamp])
  @@index([stationId, fuelType, timestamp])
}

model CurrentPrice {
  stationId String
  fuelType  String
  price     Float
  timestamp DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  station Station @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@id([stationId, fuelType])
  @@index([timestamp])
}
